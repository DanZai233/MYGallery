# MYGallery Docker 环境变量配置示例
# 复制此文件为 .env 并根据需要修改
#
# 使用方法：
# 1. cp .env.example .env
# 2. 编辑 .env 修改配置
# 3. docker compose -f docker-compose.full.yml up -d

# 时区设置
TZ=Asia/Shanghai

# PostgreSQL 配置（仅在使用 docker-compose.full.yml 时需要）
POSTGRES_DB=mygallery
POSTGRES_USER=mygallery
POSTGRES_PASSWORD=your_strong_password_here

# MinIO 配置（仅在使用 docker-compose.full.yml 时需要）
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_strong_minio_password

# JWT 密钥（生产环境务必修改为随机字符串）
# 可使用以下命令生成：openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-32-character-string

# 管理员初始密码
ADMIN_PASSWORD=admin123

# 图片最大上传大小（字节，默认 50MB）
MAX_UPLOAD_SIZE=52428800

# 缩略图质量（1-100，默认 85）
THUMBNAIL_QUALITY=85
